# CreDeFi Backend – Environment Variables
# =========================================
# Copy this file to .env and fill in values.
# The app WILL NOT START without a valid JWT_SECRET_KEY.

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_SECURE_PASSWORD@localhost:5432/credefi

# ── Authentication (REQUIRED) ────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=REPLACE_WITH_A_STRONG_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Token Encryption (REQUIRED for GitHub OAuth) ─────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY

# ── CORS ──────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Blockchain ────────────────────────────────────────────────────
CHAIN_RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337
CHAIN_PRIVATE_KEY=

# ── GitHub OAuth ──────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=

# ── Debug (set to false in production) ────────────────────────────
DEBUG=true
