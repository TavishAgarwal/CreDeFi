APP_NAME=CreDeFi
APP_VERSION=0.1.0
DEBUG=true

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/credefi

JWT_SECRET_KEY=replace-with-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

CORS_ORIGINS=["http://localhost:3000"]

# GitHub OAuth (create app at https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Stripe API (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=

# Alchemy Web3 API (https://www.alchemy.com/)
ALCHEMY_API_KEY=
ALCHEMY_NETWORK=eth-mainnet

# Fernet encryption key for OAuth tokens at rest (32+ chars)
TOKEN_ENCRYPTION_KEY=

# Background sync interval in seconds (default 1 hour)
SYNC_INTERVAL_SECONDS=3600
