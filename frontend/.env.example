# ── Frontend Environment Variables ─────────────────────────────────
# Copy to .env.local and fill in values

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Blockchain chain ID (31337 = Hardhat local, 1 = Ethereum mainnet)
NEXT_PUBLIC_CHAIN_ID=31337

# Contract addresses (set after deploying with `npx hardhat run scripts/deploy.js`)
NEXT_PUBLIC_LOAN_CONTRACT_ADDRESS=
NEXT_PUBLIC_VAULT_CONTRACT_ADDRESS=
NEXT_PUBLIC_NFT_CONTRACT_ADDRESS=
NEXT_PUBLIC_RATE_MODEL_ADDRESS=
